/*  ============================================================
    SKILL-LYNC – fact.Final_Table  (Full Rebuild)
    ------------------------------------------------------------
    Updated : 2026-03-04
    Changes : 1. Added Enroll_Month_Bucket_Capped (M+0…M+12, Lead Capture only)
              2. Added lead_star_rank from lead_filtered_view via unified_leads
              3. Added Program_Interested (Lead Capture only)
              4. Replaced enroll_dates CTE with salesData as enrollment source
              5. Added sales columns (sale_value, sale_program, sale_type_group, etc.)
    ============================================================ */

DROP TABLE IF EXISTS fact.Final_Table;

CREATE TABLE fact.Final_Table
AS

/* =========================================================
   1. ACTIVITY TYPE CLASSIFICATION
   ========================================================= */
WITH activity_type_logic AS (
    SELECT
        ua.*,
        CASE
            WHEN ua.activity_type_activity_code IN (
                239,270,254,284,332,267,305,299,234,263,209,354,3,221,
                924,925,926,927,929,928,922,923,310,23,292,271,
                399,281,432,404,405,412,410,411,406,428,272,226,
                240,268,343,398,516,521,513,514,520,282
            ) THEN 'Lead Capture'

            WHEN ua.activity_type_activity_code IN (315,316,259,290,920)
                THEN 'Demo Scheduled'

            WHEN ua.activity_type_activity_code IN (319)
                THEN 'Demo Cancelled'

            WHEN ua.activity_type_activity_code IN (318)
                THEN 'Demo Rescheduled'

            WHEN ua.activity_type_activity_code IN (342,921,397)
                THEN 'Demo Completed - Webinars'

            WHEN ua.activity_type_activity_code IN (393)
                THEN 'SE Marked Demo Schedule'

            WHEN ua.activity_type_activity_code IN (395)
                THEN 'SE Marked Demo Completed'

            WHEN ua.activity_type_activity_code IN (98,9629)
                THEN 'Payment Activity'

            WHEN ua.activity_type_activity_code IN (506)
                THEN 'Call Activity'

            WHEN ua.activity_type_activity_code IN (2,510)
                THEN 'Page Visit'

            WHEN ua.activity_type_activity_code = 2200
                THEN 'Lead Assignment Activity'

            ELSE 'Other / Unknown'
        END AS activity_type_category
    FROM prep.vw_unified_activity_with_source_attribution ua
),

/* =========================================================
   2. BASE SOURCE BUCKET (ACTIVITY LEVEL)
   ========================================================= */
base_with_source_bucket AS (
    SELECT
        atl.*,
        CASE
            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%grow.skill-lync.com%'
                 OR LOWER(lc_source) LIKE '%direct grow%'
                )
                THEN 'Direct Grow'

            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%youtube%'
                 OR LOWER(lc_source) LIKE '%yt%'
                 OR LOWER(lc_source) LIKE '%google_video%'
                 OR LOWER(lc_source) LIKE '%video_ad%'
                )
                THEN 'Youtube'

            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%facebook%'
                 OR LOWER(lc_source) LIKE '%fb%'
                 OR LOWER(lc_source) LIKE '%insta%'
                 OR LOWER(lc_source) LIKE '%instagram%'
                 OR LOWER(lc_source) LIKE '%meta%'
                )
                THEN 'Meta'

            WHEN lc_source IS NOT NULL
             AND LOWER(lc_source) LIKE '%linkedin%'
                THEN 'Linkedin'

            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%google ads%'
                 OR LOWER(lc_source) LIKE '%google_search%'
                 OR LOWER(lc_source) LIKE '%search_ad%'
                )
                THEN 'Google Ads'

            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%email%'
                 OR LOWER(lc_source) LIKE '%webengage%'
                 OR LOWER(lc_source) LIKE '%kasplo%'
                )
                THEN 'Email'

            WHEN lc_source IS NOT NULL
             AND LOWER(lc_source) LIKE '%whatsapp%'
                THEN 'Whatsapp'

            WHEN lc_source IS NOT NULL
             AND (
                    LOWER(lc_source) LIKE '%google.com%'
                 OR LOWER(lc_source) LIKE '%bing%'
                 OR LOWER(lc_source) LIKE '%yahoo%'
                 OR LOWER(lc_source) LIKE '%duckduckgo%'
                 OR LOWER(lc_source) LIKE '%yandex%'
                )
                THEN 'Organic'

            WHEN lc_source IS NOT NULL
             AND LOWER(lc_source) LIKE '%skill-lync.com%'
                THEN 'Direct'

            WHEN lc_source IS NULL
             AND (
                    LOWER(activity_type_display_name) LIKE '%facebook%'
                 OR LOWER(activity_type_display_name) LIKE '%meta%'
                 OR LOWER(activity_type_display_name) LIKE '%fb%'
                )
                THEN 'Meta'

            WHEN lc_source IS NULL
                THEN 'Email'

            WHEN lc_source IS NOT NULL
             AND LOWER(lc_source) LIKE '%resource%'
                THEN 'Skill-Lync-Resources'                  

            ELSE 'Others'
        END AS Source_Bucket
    FROM activity_type_logic atl
),

/* =========================================================
   3. LEAD + FINAL SOURCE BUCKET + DOMAIN GROUP
   ========================================================= */
base_with_lead_and_final_source AS (
    SELECT
        b.*,

        CASE
            WHEN b.Source_Bucket <> 'Email'
                THEN b.Source_Bucket

            WHEN b.Source_Bucket = 'Email'
             AND (
                    LOWER(COALESCE(ul.Lead_Source_Campaign,'')) LIKE '%facebook%'
                 OR LOWER(COALESCE(ul.Lead_Source_Campaign,'')) LIKE '%fb%'
                 OR LOWER(COALESCE(ul.Lead_Source_Campaign,'')) LIKE '%meta%'
                )
                THEN 'Meta'

            ELSE b.Source_Bucket
        END AS Source_Bucket_Final,

        ul.id                                  AS lead_id,
        ul.first_name,
        ul.last_name,
        ul.email_address,
        ul.phone_country_code,
        ul.timezone,
        ul.prospect_stage,
        ul.utm_device                          AS lead_utm_device,
        ul.city                                AS lead_city,
        ul.state                               AS lead_state,
        ul.country                             AS lead_country,
        ul.age,
        ul.created_on                          AS lead_created_on,
        ul.current_owner_assignment_id,
        ul.owner_id                            AS lead_owner_id,
        ul.is_customer,

        ul.prospect_id                         AS lead_ext_prospect_id,
        ul.mx_degree,
        ul.mx_department,
        ul.mx_lead_branch,
        ul.mx_department_name,
        ul.mx_domain,
        ul.mx_skill_centre_location,
        ul.mx_lead_background,
        ul.mx_lead_goal,
        ul.mx_year_of_passing,
        ul.mx_device,
        ul.mx_company_name,
        ul.mx_job_title,
        ul.mx_designation,
        ul.mx_job_experience,
        ul.mx_current_education_status,
        ul.mx_branch_of_education,
        ul.mx_working_professional_or_experienced,
        ul.mx_years_of_experience,
        ul.mx_student_or_working_professional,
        ul.mx_interested_courses,
        ul.mx_course_interested_in,
        ul.mx_webinar_interest,

        ul.Lead_Source,
        ul.Lead_Source_Medium,
        ul.Lead_Source_Campaign,
        ul.star_rank,
        ul.first_source,
        ul.lead_star_rank,

        CASE
            WHEN LOWER(ul.mx_domain) IN ('mechanical','mech','manufacturing')
                THEN 'Mechanical'
            WHEN LOWER(ul.mx_domain) IN ('ev','hev')
                THEN 'Electric Vehicles'
            WHEN LOWER(ul.mx_domain) LIKE '%embedded%'
                THEN 'Embedded Systems'
            WHEN LOWER(ul.mx_domain) IN ('information tech','fsd')
                THEN 'Software / IT'
            WHEN LOWER(ul.mx_domain) = 'fea'
                THEN 'CAE / Simulation'
            WHEN LOWER(ul.mx_domain) LIKE '%electr%'
                THEN 'Electrical'
            WHEN LOWER(ul.mx_domain) LIKE '%design%'
                THEN 'Design'
            WHEN LOWER(ul.mx_domain) LIKE '%civil%'
                THEN 'Civil'
            ELSE 'Others / Unknown'
        END AS Domain_group

    FROM base_with_source_bucket b
    LEFT JOIN prep.unified_leads ul
        ON b.prospect_id = ul.id
),

/* =========================================================
   4. LEAD CAPTURE EVENTS
   ========================================================= */
lead_capture_activities AS (
    SELECT
        lead_id,
        created_at AS activity_created_at,
        Source_Bucket_Final,
        DATEFROMPARTS(YEAR(created_at), MONTH(created_at), 1) AS activity_month
    FROM base_with_lead_and_final_source
    WHERE activity_type_category = 'Lead Capture'
),

/* =========================================================
   5. FIRST LEAD CAPTURE SOURCE PER MONTH
   ========================================================= */
first_lead_capture_of_month AS (
    SELECT
        lead_id,
        activity_month,
        Source_Bucket_Final AS first_lead_capture_source_of_month,
        activity_created_at AS first_capture_date_of_month
    FROM (
        SELECT
            lead_id,
            activity_month,
            Source_Bucket_Final,
            activity_created_at,
            ROW_NUMBER() OVER (
                PARTITION BY lead_id, activity_month
                ORDER BY activity_created_at
            ) AS rn
        FROM lead_capture_activities
    ) t
    WHERE rn = 1
),

/* =========================================================
   5b. LAST LEAD CAPTURE SOURCE PER LEAD (RUNNING)
   ========================================================= */
last_lead_capture_source AS (
    SELECT
        lead_id,
        activity_created_at,
        Source_Bucket_Final AS last_lead_capture_source,
        activity_month      AS last_lead_capture_month
    FROM (
        SELECT
            lead_id,
            activity_created_at,
            Source_Bucket_Final,
            activity_month,
            ROW_NUMBER() OVER (
                PARTITION BY lead_id
                ORDER BY activity_created_at DESC
            ) AS rn
        FROM lead_capture_activities
    ) t
    WHERE rn = 1
),

/* =========================================================
   6. ENROLLMENT DATA (from salesData – first sale per lead)
   ========================================================= */
enroll_dates AS (
    SELECT
        lead_id,
        enroll_date,
        CAST(sale_value AS DECIMAL(18,2))    AS sale_value,
        sale_program,
        sale_ind_pg
    FROM (
        SELECT
            ul.id                              AS lead_id,
            CAST(sd.[Formatted Sale Date] AS DATETIME2(6)) AS enroll_date,
            sd.[Booked Sale Amount]            AS sale_value,
            sd.[Program Chosen by Lead]        AS sale_program,
            sd.[Enrollment Type]               AS sale_ind_pg,
            ROW_NUMBER() OVER (
                PARTITION BY ul.id
                ORDER BY CAST(sd.[Formatted Sale Date] AS DATETIME2(6))
            ) AS rn
        FROM prep.unified_leads ul
        INNER JOIN dbo.SkillLyncSalesData sd
            ON LOWER(TRIM(ul.email_address)) = LOWER(TRIM(sd.[Lead Email]))
    ) t
    WHERE rn = 1
),

/* =========================================================
   7. ASSIGNMENT RANK AT MONTH LEVEL
   ========================================================= */
assignment_rank_month AS (
    SELECT
        lead_id,
        activity_month,
        prospect_star_rank_at_assign AS rank_at_assignment_month,
        p1_score_at_assign,
        CASE
            WHEN p1_score_at_assign >= 60 THEN '4 Star'
            WHEN p1_score_at_assign >= 40 THEN '3 Star'
            WHEN p1_score_at_assign >= 20 THEN '2 Star'
            WHEN p1_score_at_assign IS NOT NULL THEN '1 Star'
            ELSE NULL
        END AS p1_star_rank_at_assign,
        assigned_bda_id
    FROM (
        SELECT
            lead_id,
            DATEFROMPARTS(YEAR(created_at), MONTH(created_at), 1) AS activity_month,
            prospect_star_rank_at_assign,
            priority_score1          AS p1_score_at_assign,
            selected_user_id_assign  AS assigned_bda_id,
            ROW_NUMBER() OVER (
                PARTITION BY
                    lead_id,
                    DATEFROMPARTS(YEAR(created_at), MONTH(created_at), 1)
                ORDER BY created_at
            ) AS rn
        FROM base_with_lead_and_final_source
        WHERE activity_type_category = 'Lead Assignment Activity'
          AND selected_user_id_assign IS NOT NULL
    ) t
    WHERE rn = 1
),

/* =========================================================
   7b. LATEST ASSIGNED BDA PER LEAD (Overall)
       — Carries forward the most recent BDA assignment
         so every activity row has a BDA, not just
         months with a new assignment
   ========================================================= */
latest_assigned_bda AS (
    SELECT
        lead_id,
        selected_user_id_assign  AS latest_bda_id,
        priority_score1          AS latest_p1_score,
        CASE
            WHEN priority_score1 >= 60 THEN '4 Star'
            WHEN priority_score1 >= 40 THEN '3 Star'
            WHEN priority_score1 >= 20 THEN '2 Star'
            WHEN priority_score1 IS NOT NULL THEN '1 Star'
            ELSE NULL
        END AS latest_p1_star_rank,
        created_at               AS latest_assignment_date
    FROM (
        SELECT
            lead_id,
            selected_user_id_assign,
            priority_score1,
            created_at,
            ROW_NUMBER() OVER (
                PARTITION BY lead_id
                ORDER BY created_at DESC
            ) AS rn
        FROM base_with_lead_and_final_source
        WHERE activity_type_category = 'Lead Assignment Activity'
          AND selected_user_id_assign IS NOT NULL
    ) t
    WHERE rn = 1
)

/* =========================================================
   8. FINAL SELECT
   ========================================================= */
SELECT
    b.*,

    YEAR(b.created_at)  AS activity_year,
    MONTH(b.created_at) AS activity_month,
    DAY(b.created_at)   AS activity_day,
    CAST(DATENAME(MONTH, b.created_at) AS VARCHAR(20)) AS activity_month_name,

    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
        AS activity_month_start,

    DATEFROMPARTS(YEAR(b.lead_created_on), MONTH(b.lead_created_on), 1)
        AS lead_created_month,

    flc.first_lead_capture_source_of_month,

    /* Last lead capture source (for Old-Others attribution) */
    llc.last_lead_capture_source,
    llc.last_lead_capture_month,

    ed.enroll_date,
    YEAR(ed.enroll_date)  AS enroll_year,
    MONTH(ed.enroll_date) AS enroll_month,
    DAY(ed.enroll_date)   AS enroll_day,
    CAST(DATENAME(MONTH, ed.enroll_date) AS VARCHAR(20)) AS enroll_month_name,
    DATEFROMPARTS(YEAR(ed.enroll_date), MONTH(ed.enroll_date), 1) AS enroll_month_start,
    ed.sale_value,
    ed.sale_program,
    ed.sale_ind_pg,

    /* -------------------------------------------------------
       Valid Enrollment Flag  (works across ALL segments)

       New Lead / Old Lead – Capture (has Lead Capture in month):
         1 = enrolled ON or AFTER first capture date in month

       Old – Others (NO Lead Capture in month):
         1 = enrolled IN this activity month

       Uses DISTINCTCOUNT in DAX so each lead counted once
       ------------------------------------------------------- */
    CASE
        /* Segments WITH capture: enrolled in the same month as the capture */
        WHEN b.activity_type_category = 'Lead Capture'
         AND ed.enroll_date IS NOT NULL
         AND DATEFROMPARTS(YEAR(ed.enroll_date), MONTH(ed.enroll_date), 1)
             = DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
        THEN 1

        /* Old – Others: no capture this month, enrolled IN this month */
        WHEN ed.enroll_date IS NOT NULL
         AND DATEFROMPARTS(YEAR(ed.enroll_date), MONTH(ed.enroll_date), 1)
             = DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
         AND MAX(
                CASE WHEN b.activity_type_category = 'Lead Capture'
                     THEN 1 ELSE 0
                END
             ) OVER (
                PARTITION BY
                    b.lead_id,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
             ) = 0
        THEN 1

        ELSE 0
    END AS Is_Valid_Enroll,

    /* Same Month Enroll (Lead Capture rows only, valid enrolls only) */
    CASE
        WHEN b.activity_type_category = 'Lead Capture'
         AND ed.enroll_date IS NOT NULL
         AND flc.first_capture_date_of_month IS NOT NULL
         AND ed.enroll_date >= flc.first_capture_date_of_month
         AND YEAR(ed.enroll_date) = YEAR(b.created_at)
         AND MONTH(ed.enroll_date) = MONTH(b.created_at)
        THEN 'Enrolls'
        ELSE 'Leads'
    END AS SameMonthEnrolls,

    /* -------------------------------------------------------
       Enroll Month Bucket – Lead Capture rows only
       Compares against FIRST capture date in month
       ------------------------------------------------------- */
    CASE
        WHEN b.activity_type_category <> 'Lead Capture'
            THEN NULL

        WHEN ed.enroll_date IS NULL
            THEN 'Leads'

        WHEN flc.first_capture_date_of_month IS NULL
            THEN 'Leads'

        WHEN ed.enroll_date < flc.first_capture_date_of_month
            THEN 'Leads'

        WHEN DATEDIFF(
                MONTH,
                DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1),
                ed.enroll_date
             ) BETWEEN 0 AND 12
            THEN CONCAT(
                'M+',
                DATEDIFF(
                    MONTH,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1),
                    ed.enroll_date
                )
            )

        ELSE 'Leads'
    END AS Enroll_Month_Bucket_Capped,

    /* Has Lead Capture In Month */
    MAX(
        CASE
            WHEN b.activity_type_category = 'Lead Capture'
            THEN 1 ELSE 0
        END
    ) OVER (
        PARTITION BY
            b.lead_id,
            DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
    ) AS has_lead_capture_in_month,

    /* First Assignment Per Lead Per Month
       Leverages assignment_rank_month CTE which already picks the
       first real BDA assignment (selected_user_id_assign IS NOT NULL)
       per lead per month */
    CASE
        WHEN b.activity_type_category = 'Lead Assignment Activity'
         AND arm.assigned_bda_id IS NOT NULL
         AND b.lead_id = arm.lead_id
        THEN 1
        ELSE 0
    END AS Is_First_Assignment_Per_Month,

    /* Assignment Source: did this assigned lead have a capture in the same month? */
    CASE
        WHEN b.activity_type_category = 'Lead Assignment Activity'
         AND arm.assigned_bda_id IS NOT NULL
         AND MAX(
                CASE WHEN b.activity_type_category = 'Lead Capture'
                     THEN 1 ELSE 0
                END
             ) OVER (
                PARTITION BY
                    b.lead_id,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
             ) = 1
        THEN 'From Capture'
        WHEN b.activity_type_category = 'Lead Assignment Activity'
         AND arm.assigned_bda_id IS NOT NULL
        THEN 'Old Lead'
        ELSE NULL
    END AS assignment_source,

    /* Lead Segment */
    CASE
        WHEN
            MAX(
                CASE WHEN b.activity_type_category = 'Lead Capture' THEN 1 ELSE 0 END
            ) OVER (
                PARTITION BY
                    b.lead_id,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
            ) = 1
         AND DATEFROMPARTS(YEAR(b.lead_created_on), MONTH(b.lead_created_on), 1)
             = DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
            THEN 'New Lead'

        WHEN
            MAX(
                CASE WHEN b.activity_type_category = 'Lead Capture' THEN 1 ELSE 0 END
            ) OVER (
                PARTITION BY
                    b.lead_id,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
            ) = 1
         AND DATEFROMPARTS(YEAR(b.lead_created_on), MONTH(b.lead_created_on), 1)
             < DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
            THEN 'Old Lead – Capture'

        ELSE 'Old – Others'
    END AS lead_segment,

    /* Unified source attribution across all segments */
    CASE
        WHEN
            MAX(
                CASE WHEN b.activity_type_category = 'Lead Capture' THEN 1 ELSE 0 END
            ) OVER (
                PARTITION BY
                    b.lead_id,
                    DATEFROMPARTS(YEAR(b.created_at), MONTH(b.created_at), 1)
            ) = 1
            THEN flc.first_lead_capture_source_of_month

        ELSE llc.last_lead_capture_source
    END AS source_attribution_final,

    /* --- Activity Owner (from Activity_extension, resolved to name) --- */
    CONCAT(uown.first_name, ' ', uown.last_name) AS activity_owner_name,

    /* --- Assignment: month-level (NULL if no assignment that month) --- */
    arm.rank_at_assignment_month,
    arm.p1_score_at_assign,
    arm.p1_star_rank_at_assign,
    arm.assigned_bda_id,
    CONCAT(ubda_month.first_name, ' ', ubda_month.last_name) AS assigned_bda_name,
    btm.[Tier]     AS assigned_bda_tier,
    btm.[Status]   AS assigned_bda_status,

    /* --- Assignment: latest overall (always populated if ever assigned) --- */
    lab.latest_bda_id,
    CONCAT(ubda.first_name, ' ', ubda.last_name) AS latest_bda_name,
    bt.[Tier]      AS latest_bda_tier,
    bt.[Status]    AS latest_bda_status,
    lab.latest_p1_score,
    lab.latest_p1_star_rank,
    lab.latest_assignment_date,

    /* --- Unified BDA: month-level first, fallback to latest --- */
    COALESCE(arm.assigned_bda_id, lab.latest_bda_id) AS bda_id,
    COALESCE(
        CONCAT(ubda_month.first_name, ' ', ubda_month.last_name),
        CONCAT(ubda.first_name, ' ', ubda.last_name)
    ) AS bda_name,
    COALESCE(btm.[Tier], bt.[Tier]) AS bda_tier,
    COALESCE(btm.[Status], bt.[Status]) AS bda_status,

    /* Program Interested – Lead Capture rows only */
    CASE
        WHEN b.activity_type_category <> 'Lead Capture'
            THEN NULL

        WHEN b.program_name IS NOT NULL
            THEN b.program_name

        WHEN LOWER(b.lc_source) LIKE '%iit jammu%'
         AND LOWER(b.lc_source) LIKE '%design%'
            THEN 'IIT Jammu Design'

        WHEN LOWER(b.lc_source) LIKE '%iit jammu%'
         AND LOWER(b.lc_source) LIKE '%ev%'
            THEN 'IIT Jammu EV'

        ELSE NULL
    END AS Program_Interested

FROM base_with_lead_and_final_source b
LEFT JOIN first_lead_capture_of_month flc
    ON b.lead_id = flc.lead_id
   AND flc.activity_month = DATEFROMPARTS(
        YEAR(b.created_at),
        MONTH(b.created_at),
        1
   )
LEFT JOIN last_lead_capture_source llc
    ON b.lead_id = llc.lead_id
LEFT JOIN enroll_dates ed
    ON b.lead_id = ed.lead_id
LEFT JOIN assignment_rank_month arm
    ON b.lead_id = arm.lead_id
   AND arm.activity_month = DATEFROMPARTS(
        YEAR(b.created_at),
        MONTH(b.created_at),
        1
   )
LEFT JOIN latest_assigned_bda lab
    ON b.lead_id = lab.lead_id
LEFT JOIN dbo.[User] uown
    ON b.owner_id = uown.id
LEFT JOIN dbo.[User] ubda_month
    ON arm.assigned_bda_id = ubda_month.id
LEFT JOIN dbo.[User] ubda
    ON lab.latest_bda_id = ubda.id
LEFT JOIN dbo.BDATierClassification btm
    ON LOWER(ubda_month.email) = LOWER(btm.[Email])
LEFT JOIN dbo.BDATierClassification bt
    ON LOWER(ubda.email) = LOWER(bt.[Email]);
